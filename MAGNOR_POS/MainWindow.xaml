<Window x:Class="MAGNOR_POS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MAGNOR_POS"
        xmlns:views="clr-namespace:MAGNOR_POS.Views"
        mc:Ignorable="d"
        Title="MAGNOR POS - Sistema de Punto de Venta"
        Height="768"
        Width="1024"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Icon="/Assets/Images/favicon.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#146e39">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3" Opacity="0.3" BlurRadius="10"/>
            </Border.Effect>

            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="45" Height="45"
                            Background="White"
                            CornerRadius="22.5"
                            Padding="8"
                            Margin="0,0,15,0">
                        <Image Source="/Assets/Images/logo_login.png" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MAGNOR POS"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Sistema de Punto de Venta"
                                   FontSize="11"
                                   Foreground="#A5D6A7"/>
                    </StackPanel>
                </StackPanel>

                <!-- User Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- User Avatar -->
                    <Border Width="40" Height="40"
                            Background="#f78921"
                            CornerRadius="20"
                            Margin="0,0,12,0">
                        <TextBlock Text="A"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- User Details -->
                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="Administrador"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="admin"
                                   FontSize="11"
                                   Foreground="#A5D6A7"/>
                    </StackPanel>

                    <!-- Logout Button -->
                    <Button Content="Cerrar Sesión"
                            Height="35"
                            Padding="20,0"
                            Background="#cc2128"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#a81a20"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar Menu -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,1,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="0" ShadowDepth="0" Opacity="0.1" BlurRadius="10"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,10,0,0">
                <StackPanel>
                    <!-- Menu Items -->

                    <!-- Ventas/POS -->
                    <Button x:Name="BtnPOS"
                            Height="55"
                            Background="#E8F5E9"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Margin="10,5"
                            Click="BtnPOS_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="15,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="💳"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Punto de Venta"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#146e39"/>
                                                        <TextBlock Text="Realizar ventas"
                                                                   FontSize="11"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C8E6C9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Productos -->
                    <Button x:Name="BtnProducts"
                            Height="55"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Margin="10,5"
                            Click="BtnProducts_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="15,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="📦"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Productos"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333"/>
                                                        <TextBlock Text="Gestión de inventario"
                                                                   FontSize="11"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Clientes -->
                    <Button x:Name="BtnCustomers"
                            Height="55"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Margin="10,5"
                            Click="BtnCustomers_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="15,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="👥"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Clientes"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333"/>
                                                        <TextBlock Text="Base de clientes"
                                                                   FontSize="11"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Compras -->
                    <Button x:Name="BtnPurchases"
                            Height="55"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Margin="10,5"
                            Click="BtnPurchases_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="15,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="🛒"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Compras"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333"/>
                                                        <TextBlock Text="Órdenes a proveedores"
                                                                   FontSize="11"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Proveedores -->
                    <Button x:Name="BtnSuppliers"
                            Height="55"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Margin="10,5"
                            Click="BtnSuppliers_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="15,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="🏭"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Proveedores"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333"/>
                                                        <TextBlock Text="Gestión de proveedores"
                                                                   FontSize="11"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Reportes -->
                    <Button x:Name="BtnReports"
                            Height="55"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Margin="10,5"
                            Click="BtnReports_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="15,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="📊"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Reportes"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333"/>
                                                        <TextBlock Text="Análisis y estadísticas"
                                                                   FontSize="11"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Configuración -->
                    <Button x:Name="BtnSettings"
                            Height="55"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Margin="10,5"
                            Click="BtnSettings_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="15,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="⚙️"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Configuración"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333"/>
                                                        <TextBlock Text="Ajustes del sistema"
                                                                   FontSize="11"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#F5F5F5"
                Padding="20">
            <Grid>
                <!-- Dynamic Content -->
                <Border Background="White"
                        CornerRadius="15"
                        Padding="30">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="15"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock x:Name="TitleText"
                                       Text="Punto de Venta"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#146e39"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="SubtitleText"
                                       Text="Realiza ventas rápidas y gestiona el carrito de compra"
                                       FontSize="14"
                                       Foreground="#666666"/>
                        </StackPanel>

                        <!-- Dynamic Content Control -->
                        <ContentControl x:Name="MainContent"
                                       Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
