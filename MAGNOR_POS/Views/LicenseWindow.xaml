<Window x:Class="MAGNOR_POS.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MAGNOR_POS.Converters"
        Title="MAGNOR POS - Activación de Licencia"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/Images/favicon.ico">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <!-- Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E3F2FD" Offset="0"/>
                <GradientStop Color="#BBDEFB" Offset="0.5"/>
                <GradientStop Color="#90CAF9" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decorative Circles -->
        <Canvas>
            <Ellipse Width="300" Height="300"
                     Canvas.Left="-150" Canvas.Top="-150"
                     Fill="#20FFFFFF" Opacity="0.5"/>
            <Ellipse Width="500" Height="500"
                     Canvas.Right="-250" Canvas.Bottom="-250"
                     Fill="#20FFFFFF" Opacity="0.5"/>
        </Canvas>

        <!-- Floating License Card -->
        <Border Width="520"
                Height="580"
                Background="White"
                CornerRadius="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                Direction="270"
                                ShadowDepth="20"
                                Opacity="0.3"
                                BlurRadius="40"/>
            </Border.Effect>

            <Grid>
                <!-- Top Gradient Bar -->
                <Border Height="6"
                        VerticalAlignment="Top"
                        CornerRadius="20,20,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0f3460" Offset="0"/>
                            <GradientStop Color="#276691" Offset="0.5"/>
                            <GradientStop Color="#f78921" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel Margin="50,40" VerticalAlignment="Center">

                    <!-- Lock Icon -->
                    <Border Background="#E3F2FD"
                            Width="100"
                            Height="100"
                            CornerRadius="50"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center">
                        <TextBlock Text="🔑"
                                   FontSize="42"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title -->
                    <TextBlock Text="Activación de Licencia"
                               FontSize="26"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#0f3460"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Ingrese su clave de licencia para activar MAGNOR POS"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,30"/>

                    <!-- License Key Input -->
                    <TextBlock Text="Clave de Licencia"
                               FontSize="13"
                               Foreground="#555555"
                               FontWeight="Medium"
                               Margin="0,0,0,8"/>
                    <Border Background="#FAFAFA"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            Margin="0,0,0,16">
                        <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                 Height="48"
                                 FontSize="16"
                                 FontFamily="Consolas"
                                 Padding="15,0"
                                 VerticalContentAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#333333"
                                 CaretBrush="#0f3460"
                                 CharacterCasing="Upper"
                                 MaxLength="30"/>
                    </Border>

                    <!-- Hardware ID (read-only) -->
                    <TextBlock Text="ID de Máquina"
                               FontSize="11"
                               Foreground="#999999"
                               Margin="0,0,0,4"/>
                    <Border Background="#F5F5F5"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,0,0,20">
                        <TextBox Text="{Binding HardwareId, Mode=OneWay}"
                                 FontSize="10"
                                 FontFamily="Consolas"
                                 Foreground="#888888"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"/>
                    </Border>

                    <!-- Error Message -->
                    <Border Background="#FFEBEE"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,0,0,12"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#C62828"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Success Message -->
                    <Border Background="#E8F5E9"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,0,0,12"
                            Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#2E7D32"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Activate Button -->
                    <Button Content="ACTIVAR LICENCIA"
                            Command="{Binding ActivateCommand}"
                            Height="50"
                            FontSize="15"
                            FontWeight="Bold"
                            Background="#0f3460"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    BorderThickness="0">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#0f3460"
                                                                    Direction="270"
                                                                    ShadowDepth="2"
                                                                    Opacity="0.3"
                                                                    BlurRadius="8"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1a1a2e"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDBDBD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Loading Indicator -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="●"
                                   Foreground="#f78921"
                                   FontSize="16"
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Verificando licencia..."
                                   Foreground="#0f3460"
                                   FontSize="13"/>
                    </StackPanel>

                </StackPanel>

                <!-- Close Button -->
                <Button Content="✕"
                        Width="35"
                        Height="35"
                        FontSize="16"
                        Background="Transparent"
                        Foreground="#999999"
                        BorderThickness="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </Grid>
        </Border>

        <!-- Bottom Version Info -->
        <StackPanel VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30">
            <TextBlock Text="MAGNOR POS v1.0.0"
                       FontSize="12"
                       Foreground="#555555"
                       HorizontalAlignment="Center"
                       Opacity="0.7"/>
        </StackPanel>
    </Grid>
</Window>
