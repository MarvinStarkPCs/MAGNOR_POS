<Window x:Class="MAGNOR_POS.Views.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Factura - MAGNOR POS"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420" Height="600"
        ResizeMode="NoResize">

    <Border Background="White" CornerRadius="15" Margin="10"
            BorderBrush="#146e39" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="15" Opacity="0.3" ShadowDepth="3"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Factura Generada" FontSize="20" FontWeight="Bold"
                               Foreground="#146e39"/>
                    <TextBlock Text=" - " FontSize="20" Foreground="#999999"/>
                    <TextBlock x:Name="TxtInvoiceNumber" FontSize="20" FontWeight="SemiBold"
                               Foreground="#276691"/>
                </StackPanel>
                <Button Content="X" HorizontalAlignment="Right"
                        Width="30" Height="30"
                        Background="#FFEBEE" Foreground="#cc2128"
                        BorderThickness="0" FontSize="14" FontWeight="Bold"
                        Cursor="Hand" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#cc2128"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Receipt Preview -->
            <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="8"
                    BorderBrush="#E0E0E0" BorderThickness="1" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtReceipt"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="#333333"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <!-- Buttons -->
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Imprimir"
                        Height="45" Margin="0,0,8,0"
                        Background="#276691" Foreground="White"
                        BorderThickness="0" FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnPrint_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1e5275"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="1" Content="Cerrar"
                        Height="45" Margin="8,0,0,0"
                        Background="#E0E0E0" Foreground="#333333"
                        BorderThickness="0" FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#BDBDBD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
