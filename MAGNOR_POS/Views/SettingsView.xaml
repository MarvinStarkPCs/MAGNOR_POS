<UserControl x:Class="MAGNOR_POS.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F9FAFB">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Margin" Value="0,20,0,15"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6B7280"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <TextBlock Text="⚙️ Configuración del Sistema"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#146e39"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                    CornerRadius="8" Padding="30" Margin="0,0,0,15">
                <StackPanel>
                    <!-- Company Information Section -->
                    <TextBlock Text="🏢 Información de la Empresa" Style="{StaticResource SectionTitleStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nombre de la Empresa" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                            <TextBlock Text="Dirección" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                            <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NIT" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CompanyNit, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                            <TextBlock Text="Teléfono" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                        </StackPanel>
                    </Grid>

                    <!-- Tax and Currency Section -->
                    <TextBlock Text="💰 Impuestos y Moneda" Style="{StaticResource SectionTitleStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tasa de Impuesto Predeterminada (%)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding DefaultTaxRatePercent, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                     Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                            <TextBlock Text="Actualmente: IVA 19% (Colombia)" FontSize="12" Foreground="#6B7280" Margin="0,-10,0,15"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Moneda" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Currency, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15" IsReadOnly="True"/>
                            <TextBlock Text="Peso Colombiano (COP)" FontSize="12" Foreground="#6B7280" Margin="0,-10,0,15"/>
                        </StackPanel>
                    </Grid>

                    <!-- Business Rules Section -->
                    <TextBlock Text="📋 Reglas de Negocio" Style="{StaticResource SectionTitleStyle}"/>

                    <StackPanel Margin="0,0,0,20">
                        <CheckBox Content="Habilitar alertas de inventario bajo"
                                  IsChecked="{Binding EnableInventoryAlerts}"
                                  FontSize="14" Margin="0,5"/>
                        <TextBlock Text="Notifica cuando los productos alcancen el stock mínimo"
                                   FontSize="12" Foreground="#6B7280" Margin="25,0,0,10"/>

                        <CheckBox Content="Requerir cliente en todas las ventas"
                                  IsChecked="{Binding RequireCustomerOnSale}"
                                  FontSize="14" Margin="0,5"/>
                        <TextBlock Text="Obliga a seleccionar un cliente antes de completar una venta"
                                   FontSize="12" Foreground="#6B7280" Margin="25,0,0,10"/>

                        <CheckBox Content="Habilitar descuentos en ventas"
                                  IsChecked="{Binding EnableDiscounts}"
                                  FontSize="14" Margin="0,5"/>
                        <TextBlock Text="Permite aplicar descuentos en productos y ventas"
                                   FontSize="12" Foreground="#6B7280" Margin="25,0,0,10"/>
                    </StackPanel>

                    <!-- Business Type Configuration -->
                    <TextBlock Text="🏪 Tipo de Negocio" Style="{StaticResource SectionTitleStyle}"/>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Selecciona el tipo de negocio" Style="{StaticResource LabelStyle}"/>
                        <ComboBox SelectedItem="{Binding BusinessType}"
                                  FontSize="14" Padding="10"
                                  BorderBrush="#D1D5DB" BorderThickness="1"
                                  Margin="0,0,0,15">
                            <ComboBoxItem Content="Retail (Tienda/Comercio)" Tag="Retail"/>
                            <ComboBoxItem Content="Restaurant (Restaurante/Cafetería)" Tag="Restaurant"/>
                        </ComboBox>
                        <TextBlock Text="Define si el negocio es una tienda minorista o un restaurante"
                                   FontSize="12" Foreground="#6B7280" Margin="0,-10,0,15"/>
                    </StackPanel>

                    <!-- Product Display Settings -->
                    <TextBlock Text="🎨 Apariencia de Productos" Style="{StaticResource SectionTitleStyle}"/>

                    <StackPanel Margin="0,0,0,20">
                        <CheckBox Content="Mostrar iconos en productos"
                                  IsChecked="{Binding ShowProductIcons}"
                                  FontSize="14" Margin="0,5"/>
                        <TextBlock Text="Los productos mostrarán iconos visuales en el POS"
                                   FontSize="12" Foreground="#6B7280" Margin="25,0,0,10"/>

                        <TextBlock Text="Icono predeterminado" Style="{StaticResource LabelStyle}" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding DefaultProductIcon, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}" Margin="0,0,0,5"
                                 MaxLength="2"/>
                        <TextBlock Text="Emoji que se mostrará si un producto no tiene icono asignado (ej: 📦, 🍔, 🍕, ☕)"
                                   FontSize="12" Foreground="#6B7280" Margin="0,0,0,15"/>
                    </StackPanel>

                    <!-- Restaurant Features Section -->
                    <Border Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="2"
                            CornerRadius="8" Padding="20" Margin="0,0,0,20"
                            Visibility="{Binding IsRestaurantMode, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="🍽️ Funciones de Restaurante"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#1E40AF" Margin="0,0,0,15"/>

                            <CheckBox Content="Habilitar modo restaurante"
                                      IsChecked="{Binding EnableRestaurantMode}"
                                      FontSize="14" Margin="0,5"
                                      FontWeight="SemiBold"/>
                            <TextBlock Text="Activa características específicas para restaurantes"
                                       FontSize="12" Foreground="#4B5563" Margin="25,0,0,15"/>

                            <CheckBox Content="Gestión de mesas"
                                      IsChecked="{Binding EnableTableManagement}"
                                      IsEnabled="{Binding EnableRestaurantMode}"
                                      FontSize="14" Margin="0,5"/>
                            <TextBlock Text="Permite crear y gestionar mesas, zonas y ocupación"
                                       FontSize="12" Foreground="#4B5563" Margin="25,0,0,10"/>

                            <CheckBox Content="Órdenes a cocina"
                                      IsChecked="{Binding EnableKitchenOrders}"
                                      IsEnabled="{Binding EnableRestaurantMode}"
                                      FontSize="14" Margin="0,5"/>
                            <TextBlock Text="Envía órdenes directamente a la cocina para preparación"
                                       FontSize="12" Foreground="#4B5563" Margin="25,0,0,15"/>

                            <!-- Configure Tables Button -->
                            <Button Content="⚙️ Configurar Mesas y Zonas"
                                    Command="{Binding ConfigureTablesCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Visibility="{Binding EnableTableManagement, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Border>

                    <!-- System Information Section -->
                    <TextBlock Text="ℹ️ Información del Sistema" Style="{StaticResource SectionTitleStyle}"/>

                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Versión:" FontSize="14" Foreground="#374151"/>
                                <TextBlock Text="1.0.0" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Base de Datos:" FontSize="14" Foreground="#374151"/>
                                <TextBlock Text="SQLite" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid>
                                <TextBlock Text="Ubicación BD:" FontSize="14" Foreground="#374151"/>
                                <TextBlock Text="%LocalAppData%\MAGNOR_POS\magnor_pos.db"
                                           FontSize="12" Foreground="#6B7280"
                                           HorizontalAlignment="Right" TextWrapping="Wrap"
                                           MaxWidth="400"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Warning Note -->
                    <Border Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1"
                            CornerRadius="8" Padding="15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Top"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#92400E">
                                <Run Text="Nota Importante:" FontWeight="Bold"/>
                                <LineBreak/>
                                Los cambios en la configuración afectarán el comportamiento del sistema.
                                Asegúrese de guardar los cambios antes de salir de esta pantalla.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Restaurar Predeterminados"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResetSettingsCommand}"/>
                    <Button Content="Guardar Configuración"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
