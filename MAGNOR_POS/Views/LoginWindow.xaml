<Window x:Class="MAGNOR_POS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MAGNOR POS - Login"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/Images/favicon.ico">

    <Grid>
        <!-- Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0"/>
                <GradientStop Color="#C8E6C9" Offset="0.5"/>
                <GradientStop Color="#A5D6A7" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decorative Circles -->
        <Canvas>
            <Ellipse Width="300" Height="300"
                     Canvas.Left="-150" Canvas.Top="-150"
                     Fill="#20FFFFFF" Opacity="0.5"/>
            <Ellipse Width="500" Height="500"
                     Canvas.Right="-250" Canvas.Bottom="-250"
                     Fill="#20FFFFFF" Opacity="0.5"/>
        </Canvas>

        <!-- Floating Login Card -->
        <Border Width="480"
                Height="620"
                Background="White"
                CornerRadius="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                Direction="270"
                                ShadowDepth="20"
                                Opacity="0.3"
                                BlurRadius="40"/>
            </Border.Effect>

            <Grid>
                <!-- Top Gradient Bar -->
                <Border Height="6"
                        VerticalAlignment="Top"
                        CornerRadius="20,20,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#146e39" Offset="0"/>
                            <GradientStop Color="#276691" Offset="0.5"/>
                            <GradientStop Color="#f78921" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel Margin="50,40" VerticalAlignment="Center">

                    <!-- Logo with Circle Background -->
                    <Border Background="#F5F5F5"
                            Width="140"
                            Height="140"
                            CornerRadius="70"
                            Padding="20"
                            Margin="0,0,0,25"
                            HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#CCCCCC"
                                            Direction="270"
                                            ShadowDepth="3"
                                            Opacity="0.2"
                                            BlurRadius="10"/>
                        </Border.Effect>
                        <Image Source="/Assets/Images/logo_login.png"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Title -->
                    <TextBlock Text="MAGNOR POS"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#146e39"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Sistema de Punto de Venta"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               Foreground="#666666"
                               Margin="0,0,0,35"/>

                    <!-- Username Input -->
                    <TextBlock Text="Usuario"
                               FontSize="13"
                               Foreground="#555555"
                               FontWeight="Medium"
                               Margin="0,0,0,8"/>
                    <Border Background="#FAFAFA"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            Margin="0,0,0,20">
                        <TextBox x:Name="UsernameTextBox"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Height="48"
                                 FontSize="15"
                                 Padding="15,0"
                                 VerticalContentAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#333333"
                                 CaretBrush="#146e39"/>
                    </Border>

                    <!-- Password Input -->
                    <TextBlock Text="Contraseña"
                               FontSize="13"
                               Foreground="#555555"
                               FontWeight="Medium"
                               Margin="0,0,0,8"/>
                    <Border Background="#FAFAFA"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            Margin="0,0,0,20">
                        <PasswordBox x:Name="PasswordBox"
                                     Height="48"
                                     FontSize="15"
                                     Padding="15,0"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#333333"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                    </Border>

                    <!-- Error Message -->
                    <Border Background="#FFEBEE"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,0,0,20"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#C62828"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Login Button -->
                    <Button Content="INICIAR SESIÓN"
                            Command="{Binding LoginCommand}"
                            Height="50"
                            FontSize="15"
                            FontWeight="Bold"
                            Background="#146e39"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                            Margin="0,0,0,15">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    BorderThickness="0">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#146e39"
                                                                    Direction="270"
                                                                    ShadowDepth="2"
                                                                    Opacity="0.3"
                                                                    BlurRadius="8"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0d5028"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDBDBD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Loading Indicator -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="●"
                                   Foreground="#f78921"
                                   FontSize="16"
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Iniciando sesión..."
                                   Foreground="#146e39"
                                   FontSize="13"/>
                    </StackPanel>

                    <!-- Footer Info -->
                    <StackPanel Margin="0,20,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Usuario por defecto: "
                                   Foreground="#999999"
                                   FontSize="11"/>
                        <TextBlock Text="admin / admin123"
                                   Foreground="#276691"
                                   FontWeight="SemiBold"
                                   FontSize="11"/>
                    </StackPanel>

                </StackPanel>

                <!-- Close Button -->
                <Button Content="✕"
                        Width="35"
                        Height="35"
                        FontSize="16"
                        Background="Transparent"
                        Foreground="#999999"
                        BorderThickness="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </Grid>
        </Border>

        <!-- Bottom Version Info -->
        <StackPanel VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30">
            <TextBlock Text="Versión 1.0.0"
                       FontSize="12"
                       Foreground="#555555"
                       HorizontalAlignment="Center"
                       Opacity="0.7"/>
            <TextBlock Text="© 2024 MAGNOR. Todos los derechos reservados."
                       FontSize="11"
                       Foreground="#666666"
                       HorizontalAlignment="Center"
                       Opacity="0.6"
                       Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Window>
