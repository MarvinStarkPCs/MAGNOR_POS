<Window x:Class="MAGNOR_POS.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Procesar Pago - MAGNOR POS"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="500" Height="620"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Radio Button Style for Payment Type -->
        <Style x:Key="PaymentRadioStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="#F5F5F5"
                                BorderBrush="#D0D0D0" BorderThickness="1.5"
                                CornerRadius="8" Padding="10,12" Cursor="Hand">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8F5E9"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#146e39"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Amount Button Style -->
        <Style x:Key="QuickAmountStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#276691"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E3F2FD" BorderBrush="#90CAF9"
                                BorderThickness="1" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="15" Margin="10"
            BorderBrush="#146e39" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="15" Opacity="0.3" ShadowDepth="3"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Procesar Pago"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#146e39"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <Button Content="X" HorizontalAlignment="Right"
                        Width="35" Height="35"
                        Background="#FFEBEE" Foreground="#cc2128"
                        BorderThickness="0" FontSize="16" FontWeight="Bold"
                        Cursor="Hand" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#cc2128"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Total Display -->
            <Border Grid.Row="1" Background="#E8F5E9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL A PAGAR" FontSize="14" Foreground="#666666"
                               HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtTotal" FontSize="36" FontWeight="Bold"
                               Foreground="#146e39" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Payment Method -->
            <TextBlock Grid.Row="2" Text="Forma de Pago:" FontSize="14" FontWeight="SemiBold"
                       Foreground="#333333" Margin="0,0,0,8"/>

            <Grid Grid.Row="3" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <RadioButton Grid.Column="0" x:Name="RbEfectivo" Content="Efectivo"
                             IsChecked="True" GroupName="PaymentType"
                             FontSize="13" Margin="0,0,5,0" Cursor="Hand"
                             Checked="PaymentType_Changed"
                             Style="{StaticResource PaymentRadioStyle}"/>

                <RadioButton Grid.Column="1" x:Name="RbTarjeta" Content="Tarjeta"
                             GroupName="PaymentType"
                             FontSize="13" Margin="5,0,5,0" Cursor="Hand"
                             Checked="PaymentType_Changed"
                             Style="{StaticResource PaymentRadioStyle}"/>

                <RadioButton Grid.Column="2" x:Name="RbTransferencia" Content="Transfer."
                             GroupName="PaymentType"
                             FontSize="13" Margin="5,0,0,0" Cursor="Hand"
                             Checked="PaymentType_Changed"
                             Style="{StaticResource PaymentRadioStyle}"/>
            </Grid>

            <!-- Amount Paid -->
            <StackPanel Grid.Row="4" Margin="0,0,0,10">
                <TextBlock Text="Monto Recibido:" FontSize="14" FontWeight="SemiBold"
                           Foreground="#333333" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtAmountPaid"
                         FontSize="24" FontWeight="Bold"
                         Height="55" Padding="15,0"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Right"
                         Foreground="#146e39"
                         BorderBrush="#D0D0D0" BorderThickness="1.5"
                         TextChanged="TxtAmountPaid_TextChanged"
                         PreviewTextInput="TxtAmountPaid_PreviewTextInput"
                         GotFocus="TxtAmountPaid_GotFocus">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="White"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>

            <!-- Quick Amount Buttons (only for cash) -->
            <WrapPanel Grid.Row="5" x:Name="QuickAmountPanel" Margin="0,0,0,10">
                <Button Content="Exacto" Tag="0" Click="QuickAmount_Click"
                        Style="{StaticResource QuickAmountStyle}"/>
                <Button Content="$5.000" Tag="5000" Click="QuickAmount_Click"
                        Style="{StaticResource QuickAmountStyle}"/>
                <Button Content="$10.000" Tag="10000" Click="QuickAmount_Click"
                        Style="{StaticResource QuickAmountStyle}"/>
                <Button Content="$20.000" Tag="20000" Click="QuickAmount_Click"
                        Style="{StaticResource QuickAmountStyle}"/>
                <Button Content="$50.000" Tag="50000" Click="QuickAmount_Click"
                        Style="{StaticResource QuickAmountStyle}"/>
                <Button Content="$100.000" Tag="100000" Click="QuickAmount_Click"
                        Style="{StaticResource QuickAmountStyle}"/>
            </WrapPanel>

            <!-- Change Display -->
            <Border Grid.Row="6" x:Name="ChangePanel"
                    Background="#FFF3E0" CornerRadius="10" Padding="15" Margin="0,0,0,15"
                    Visibility="Collapsed">
                <Grid>
                    <TextBlock Text="CAMBIO:" FontSize="16" FontWeight="SemiBold"
                               Foreground="#E65100" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtChange" FontSize="24" FontWeight="Bold"
                               Foreground="#E65100" HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar"
                        Height="50" Margin="0,0,10,0"
                        Background="#E0E0E0" Foreground="#333333"
                        BorderThickness="0" FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#BDBDBD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="1" x:Name="BtnConfirm"
                        Content="CONFIRMAR PAGO" IsEnabled="False"
                        Height="50"
                        Background="#146e39" Foreground="White"
                        BorderThickness="0" FontSize="16" FontWeight="Bold"
                        Cursor="Hand" Click="BtnConfirm_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0d5028"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#BDBDBD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
