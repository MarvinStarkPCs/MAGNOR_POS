<UserControl x:Class="MAGNOR_POS.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="White">

    <Grid>
        <!-- Main content when not adding/editing/adjusting stock -->
        <Grid Visibility="{Binding IsAddEditVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Statistics Cards -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Products Card -->
                <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Total Productos"
                                   FontSize="12"
                                   Foreground="#666666"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TotalProducts, Mode=OneWay}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#146e39"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock Card -->
                <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="10" Padding="20" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="⚠️" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Stock Bajo"
                                   FontSize="12"
                                   Foreground="#666666"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding LowStockCount, Mode=OneWay}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#f78921"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Inventory Value Card -->
                <Border Grid.Column="2" Background="#E3F2FD" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Valor Inventario"
                                   FontSize="12"
                                   Foreground="#666666"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,5"/>
                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#276691"
                                   HorizontalAlignment="Center">
                            <Run Text="$"/>
                            <Run Text="{Binding TotalInventoryValue, Mode=OneWay, StringFormat=N0}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filter Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="📋 Todos"
                        Height="38"
                        Padding="15,0"
                        BorderThickness="0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Margin="0,0,8,0"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Todos">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFilter}" Value="Todos">
                                    <Setter Property="Background" Value="#146e39"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="⚠️ Stock Bajo"
                        Height="38"
                        Padding="15,0"
                        BorderThickness="0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Margin="0,0,8,0"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Stock Bajo">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFilter}" Value="Stock Bajo">
                                    <Setter Property="Background" Value="#f78921"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="❌ Sin Stock"
                        Height="38"
                        Padding="15,0"
                        BorderThickness="0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Sin Stock">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFilter}" Value="Sin Stock">
                                    <Setter Property="Background" Value="#cc2128"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Top Bar with Search and Add Button -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Bar -->
                <Border Grid.Column="0"
                        Background="#FAFAFA"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1.5"
                        CornerRadius="10"
                        Margin="0,0,15,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="45"
                                 FontSize="14"
                                 Padding="15,0"
                                 VerticalContentAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#333333"
                                 CaretBrush="#146e39"/>

                        <TextBlock Grid.Column="0"
                                   Text="🔍 Buscar producto por nombre, SKU o código..."
                                   FontSize="14"
                                   Foreground="#999999"
                                   Padding="15,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Grid.Column="1"
                                Content="⌫"
                                Width="45"
                                Height="45"
                                Background="Transparent"
                                Foreground="#666666"
                                BorderThickness="0"
                                FontSize="18"
                                Cursor="Hand"
                                Command="{Binding ClearSearchCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="0,10,10,0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0F0F0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Add Button -->
                <Button Grid.Column="1"
                        Content="➕ AGREGAR PRODUCTO"
                        Height="45"
                        Padding="20,0"
                        Background="#146e39"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Command="{Binding AddNewCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0d5028"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Products DataGrid -->
            <Border Grid.Row="3"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1.5"
                    CornerRadius="10">
                <DataGrid ItemsSource="{Binding FilteredProducts}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0F0F0"
                          RowHeight="60"
                          FontSize="13"
                          Background="White"
                          BorderThickness="0">

                    <DataGrid.Columns>
                        <!-- Icon -->
                        <DataGridTextColumn Header="📦" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding ImageUrl}"/>
                                    <Setter Property="FontSize" Value="32"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Name -->
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- SKU -->
                        <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="120" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Sale Price -->
                        <DataGridTextColumn Header="Precio Venta" Binding="{Binding SalePrice, StringFormat='$ {0:N0}'}" Width="130" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#146e39"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Stock -->
                        <DataGridTextColumn Header="Stock" Binding="{Binding CurrentStock}" Width="80" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Acciones" Width="260">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="📊 Stock"
                                                Height="35"
                                                Padding="12,0"
                                                Background="#f78921"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="12"
                                                Cursor="Hand"
                                                Margin="0,0,8,0"
                                                Command="{Binding DataContext.AdjustStockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#d67219"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="✏️ Editar"
                                                Height="35"
                                                Padding="12,0"
                                                Background="#276691"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="12"
                                                Cursor="Hand"
                                                Margin="0,0,8,0"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#1e5275"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="🗑️"
                                                Width="35"
                                                Height="35"
                                                Background="#cc2128"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="16"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#a81a20"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F9F9F9"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Stock Adjustment Dialog -->
        <Border Visibility="{Binding IsStockAdjustVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1.5"
                CornerRadius="15"
                Width="500"
                Padding="30"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="10" Opacity="0.3" BlurRadius="30"/>
            </Border.Effect>

            <StackPanel>
                <!-- Header -->
                <TextBlock Text="📊 Ajustar Inventario"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#146e39"
                           Margin="0,0,0,10"/>

                <TextBlock FontSize="14" Foreground="#666666" Margin="0,0,0,25">
                    <Run Text="Producto: "/>
                    <Run Text="{Binding SelectedProduct.Name, Mode=OneWay}" FontWeight="Bold"/>
                </TextBlock>

                <!-- Adjustment Type -->
                <TextBlock Text="Tipo de Movimiento"
                           FontSize="13"
                           Foreground="#555555"
                           FontWeight="Medium"
                           Margin="0,0,0,8"/>
                <ComboBox SelectedItem="{Binding StockAdjustmentType}"
                          Height="45"
                          FontSize="14"
                          Padding="15,0"
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="Entrada" IsSelected="True"/>
                    <ComboBoxItem Content="Salida"/>
                </ComboBox>

                <!-- Quantity -->
                <TextBlock Text="Cantidad"
                           FontSize="13"
                           Foreground="#555555"
                           FontWeight="Medium"
                           Margin="0,0,0,8"/>
                <TextBox Text="{Binding StockQuantity, UpdateSourceTrigger=PropertyChanged}"
                         Height="45"
                         FontSize="14"
                         Padding="15,0"
                         BorderBrush="#D0D0D0"
                         BorderThickness="1.5"
                         Margin="0,0,0,15"/>

                <!-- Reason -->
                <TextBlock Text="Motivo"
                           FontSize="13"
                           Foreground="#555555"
                           FontWeight="Medium"
                           Margin="0,0,0,8"/>
                <TextBox Text="{Binding StockReason, UpdateSourceTrigger=PropertyChanged}"
                         Height="70"
                         FontSize="14"
                         Padding="15,10"
                         BorderBrush="#D0D0D0"
                         BorderThickness="1.5"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,25"/>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="❌ CANCELAR"
                            Height="45"
                            Padding="25,0"
                            Background="#E0E0E0"
                            Foreground="#333333"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Margin="0,0,15,0"
                            Command="{Binding CancelStockAdjustmentCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="💾 GUARDAR"
                            Height="45"
                            Padding="25,0"
                            Background="#146e39"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Command="{Binding SaveStockAdjustmentCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0d5028"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Add/Edit Form (previous implementation remains the same but truncated here for space) -->
        <!-- You can keep the existing form from the previous implementation -->
    </Grid>
</UserControl>
