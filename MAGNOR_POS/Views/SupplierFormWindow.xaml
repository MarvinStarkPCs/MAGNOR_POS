<Window x:Class="MAGNOR_POS.Views.SupplierFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:MAGNOR_POS.Models.Enums"
        Title="Proveedor - MAGNOR POS"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="580" Height="680"
        ResizeMode="NoResize">

    <Border Background="White" CornerRadius="15" Margin="10"
            BorderBrush="#146e39" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="15" Opacity="0.3" ShadowDepth="3"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🏢" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="HeaderText" Text="Nuevo Proveedor"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#146e39" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right"
                        Width="35" Height="35"
                        Background="#FFEBEE" Foreground="#cc2128"
                        BorderThickness="0" FontSize="16" FontWeight="Bold"
                        Cursor="Hand" Click="CancelButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#cc2128"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                <StackPanel>

                    <!-- Section: Empresa -->
                    <TextBlock Text="Informacion de la Empresa" FontSize="14" FontWeight="SemiBold"
                               Foreground="#146e39" Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Nombre de la Empresa *" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="CompanyNameTextBox" FontSize="14" Height="42" Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#D0D0D0" BorderThickness="1.5">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Nombre de Contacto *" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="ContactNameTextBox" FontSize="14" Height="42" Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#D0D0D0" BorderThickness="1.5">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <!-- Documento -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tipo de Documento" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                            <ComboBox x:Name="DocumentTypeComboBox" Height="42" FontSize="14"
                                      VerticalContentAlignment="Center" Padding="10,0">
                                <ComboBoxItem Content="NIT" Tag="{x:Static enums:DocumentType.NIT}" IsSelected="True"/>
                                <ComboBoxItem Content="CC" Tag="{x:Static enums:DocumentType.CedulaCiudadania}"/>
                                <ComboBoxItem Content="CE" Tag="{x:Static enums:DocumentType.CedulaExtranjeria}"/>
                                <ComboBoxItem Content="Pasaporte" Tag="{x:Static enums:DocumentType.Pasaporte}"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Numero de Documento" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                            <TextBox x:Name="DocumentNumberTextBox" FontSize="14" Height="42" Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D0D0D0" BorderThickness="1.5">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <!-- Separator -->
                    <Border BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Margin="0,5,0,15"/>

                    <!-- Section: Contacto -->
                    <TextBlock Text="Informacion de Contacto" FontSize="14" FontWeight="SemiBold"
                               Foreground="#146e39" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Telefono" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                            <TextBox x:Name="PhoneTextBox" FontSize="14" Height="42" Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D0D0D0" BorderThickness="1.5">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                            <TextBox x:Name="EmailTextBox" FontSize="14" Height="42" Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D0D0D0" BorderThickness="1.5">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Direccion" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="AddressTextBox" FontSize="14" Height="42" Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#D0D0D0" BorderThickness="1.5">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sitio Web" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                            <TextBox x:Name="WebsiteTextBox" FontSize="14" Height="42" Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D0D0D0" BorderThickness="1.5">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Plazo Pago" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                            <TextBox x:Name="PaymentTermDaysTextBox" Text="30" FontSize="14" Height="42" Padding="12,0"
                                     VerticalContentAlignment="Center" TextAlignment="Center"
                                     BorderBrush="#D0D0D0" BorderThickness="1.5">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Notas" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="NotesTextBox" FontSize="14" Height="60" Padding="12,8"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 BorderBrush="#D0D0D0" BorderThickness="1.5">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <CheckBox x:Name="IsActiveCheckBox" Content="  Proveedor activo"
                              FontSize="13" IsChecked="True" Foreground="#333333"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar"
                        Height="48"
                        Background="#E0E0E0" Foreground="#333333"
                        BorderThickness="0" FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand" Click="CancelButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#BDBDBD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" x:Name="SaveButton" Content="GUARDAR PROVEEDOR"
                        Height="48"
                        Background="#146e39" Foreground="White"
                        BorderThickness="0" FontSize="15" FontWeight="Bold"
                        Cursor="Hand" Click="SaveButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0d5028"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
