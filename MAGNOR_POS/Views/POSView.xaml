<UserControl x:Class="MAGNOR_POS.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side - Products -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search Bar -->
            <Border Grid.Row="0"
                    Background="#FAFAFA"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1.5"
                    CornerRadius="10"
                    Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="45"
                             FontSize="14"
                             Padding="15,0"
                             VerticalContentAlignment="Center"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#333333"
                             CaretBrush="#146e39"/>

                    <TextBlock Grid.Column="0"
                               Text="🔍 Buscar producto por nombre o código..."
                               FontSize="14"
                               Foreground="#999999"
                               Padding="15,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Grid.Column="1"
                            Content="⌫"
                            Width="45"
                            Height="45"
                            Background="Transparent"
                            Foreground="#666666"
                            BorderThickness="0"
                            FontSize="18"
                            Cursor="Hand"
                            Command="{Binding ClearSearchCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="0,10,10,0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Categories -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Todos"
                            Height="35"
                            Padding="20,0"
                            BorderThickness="0"
                            FontSize="13"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Command="{Binding SelectCategoryCommand}"
                            CommandParameter="Todos">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="Todos">
                                        <Setter Property="Background" Value="#146e39"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Bebidas"
                            Height="35"
                            Padding="20,0"
                            BorderThickness="0"
                            FontSize="13"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Command="{Binding SelectCategoryCommand}"
                            CommandParameter="Bebidas">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="Bebidas">
                                        <Setter Property="Background" Value="#146e39"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Alimentos"
                            Height="35"
                            Padding="20,0"
                            BorderThickness="0"
                            FontSize="13"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Command="{Binding SelectCategoryCommand}"
                            CommandParameter="Alimentos">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="Alimentos">
                                        <Setter Property="Background" Value="#146e39"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Snacks"
                            Height="35"
                            Padding="20,0"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Command="{Binding SelectCategoryCommand}"
                            CommandParameter="Snacks">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="Snacks">
                                        <Setter Property="Background" Value="#146e39"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <!-- Products Grid -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredProducts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="White"
                                    BorderThickness="0"
                                    Margin="5"
                                    Cursor="Hand"
                                    Height="140">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="#E0E0E0"
                                                            BorderThickness="1.5"
                                                            CornerRadius="12"
                                                            Padding="15">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#000000"
                                                                            Direction="270"
                                                                            ShadowDepth="1"
                                                                            Opacity="0.1"
                                                                            BlurRadius="5"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Product Icon -->
                                                            <TextBlock Grid.Row="0"
                                                                       Text="{Binding ImageUrl}"
                                                                       FontSize="50"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>

                                                            <!-- Product Name -->
                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding Name}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#333333"
                                                                       TextAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,5,0,3"/>

                                                            <!-- Product Price -->
                                                            <TextBlock Grid.Row="2"
                                                                       FontSize="16"
                                                                       FontWeight="Bold"
                                                                       Foreground="#146e39"
                                                                       TextAlignment="Center">
                                                                <Run Text="$ "/>
                                                                <Run Text="{Binding SalePrice, StringFormat=N0}"/>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Right Side - Cart -->
        <Border Grid.Column="1"
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="1.5"
                CornerRadius="15">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="🛒 Carrito de Compra"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#146e39"
                               Margin="0,0,0,5"/>
                    <TextBlock FontSize="12"
                               Foreground="#666666">
                        <Run Text="{Binding CartItems.Count, Mode=OneWay}"/>
                        <Run Text=" producto(s)"/>
                    </TextBlock>
                </StackPanel>

                <!-- Cart Items -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,15">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Product Info -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Product.Name}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#333333"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="#666666">
                                                    <Run Text="$ "/>
                                                    <Run Text="{Binding Product.SalePrice, StringFormat=N0}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Content="✕"
                                                    Width="25"
                                                    Height="25"
                                                    Background="#FFEBEE"
                                                    Foreground="#cc2128"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="12.5">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#cc2128"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>

                                        <!-- Quantity Controls -->
                                        <Grid Grid.Row="1" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="-"
                                                    Width="30"
                                                    Height="30"
                                                    Background="#276691"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1e5275"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Quantity, Mode=OneWay}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#333333"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="2"
                                                    Content="+"
                                                    Width="30"
                                                    Height="30"
                                                    Background="#146e39"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#0d5028"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Totals -->
                <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Subtotal:"
                                       FontSize="13"
                                       Foreground="#666666"
                                       HorizontalAlignment="Left"/>
                            <TextBlock FontSize="13"
                                       Foreground="#666666"
                                       HorizontalAlignment="Right">
                                <Run Text="$ "/>
                                <Run Text="{Binding Subtotal, Mode=OneWay, StringFormat=N0}"/>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="IVA (19%):"
                                       FontSize="13"
                                       Foreground="#666666"
                                       HorizontalAlignment="Left"/>
                            <TextBlock FontSize="13"
                                       Foreground="#666666"
                                       HorizontalAlignment="Right">
                                <Run Text="$ "/>
                                <Run Text="{Binding Tax, Mode=OneWay, StringFormat=N0}"/>
                            </TextBlock>
                        </Grid>

                        <Rectangle Height="1"
                                   Fill="#E0E0E0"
                                   Margin="0,5"/>

                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="TOTAL:"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#146e39"
                                       HorizontalAlignment="Left"/>
                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#146e39"
                                       HorizontalAlignment="Right">
                                <Run Text="$ "/>
                                <Run Text="{Binding Total, Mode=OneWay, StringFormat=N0}"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3">
                    <Button Content="💳 PROCESAR PAGO"
                            Height="50"
                            Background="#146e39"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Margin="0,0,0,10"
                            Command="{Binding ProcessPaymentCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0d5028"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDBDBD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🗑️ LIMPIAR CARRITO"
                            Height="40"
                            Background="#cc2128"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Command="{Binding ClearCartCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#a81a20"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
