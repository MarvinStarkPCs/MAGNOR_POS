<Window x:Class="MAGNOR_POS.Views.CustomerFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:MAGNOR_POS.Models.Enums"
        Title="Cliente" Height="700" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F9FAFB">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6B7280"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2563EB" Padding="25,20">
            <TextBlock x:Name="HeaderText" Text="Nuevo Cliente"
                       FontSize="24" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
            <StackPanel>
                <!-- Personal Information Section -->
                <TextBlock Text="Información Personal" FontSize="16" FontWeight="Bold"
                           Foreground="#1F2937" Margin="0,0,0,15"/>

                <TextBlock Text="Nombre Completo *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="FullNameTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tipo de Documento *" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="DocumentTypeComboBox" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,15">
                            <ComboBoxItem Content="Cédula de Ciudadanía (CC)" Tag="{x:Static enums:DocumentType.CedulaCiudadania}" IsSelected="True"/>
                            <ComboBoxItem Content="NIT" Tag="{x:Static enums:DocumentType.NIT}"/>
                            <ComboBoxItem Content="Cédula de Extranjería (CE)" Tag="{x:Static enums:DocumentType.CedulaExtranjeria}"/>
                            <ComboBoxItem Content="Pasaporte" Tag="{x:Static enums:DocumentType.Pasaporte}"/>
                            <ComboBoxItem Content="Tarjeta de Identidad (TI)" Tag="{x:Static enums:DocumentType.TarjetaIdentidad}"/>
                            <ComboBoxItem Content="Registro Civil" Tag="{x:Static enums:DocumentType.RegistroCivil}"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Número de Documento" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="DocumentNumberTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <!-- Contact Information Section -->
                <TextBlock Text="Información de Contacto" FontSize="16" FontWeight="Bold"
                           Foreground="#1F2937" Margin="0,10,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Teléfono" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="PhoneTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="EmailTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Dirección" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="AddressTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ciudad" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="CityTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Departamento" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="StateTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Código Postal" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="PostalCodeTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <!-- Business Information Section -->
                <TextBlock Text="Información Comercial" FontSize="16" FontWeight="Bold"
                           Foreground="#1F2937" Margin="0,10,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tipo de Cliente" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CustomerTypeComboBox" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,15">
                            <ComboBoxItem Content="Minorista" Tag="{x:Static enums:CustomerType.Minorista}" IsSelected="True"/>
                            <ComboBoxItem Content="Mayorista" Tag="{x:Static enums:CustomerType.Mayorista}"/>
                            <ComboBoxItem Content="Corporativo" Tag="{x:Static enums:CustomerType.Corporativo}"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Descuento (%)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="DiscountTextBox" Text="0" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Límite de Crédito" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="CreditLimitTextBox" Text="0" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Notas" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="NotesTextBox" Style="{StaticResource TextBoxStyle}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="80" Margin="0,0,0,15"/>

                <CheckBox x:Name="IsActiveCheckBox" Content="Cliente activo"
                          FontSize="14" IsChecked="True" Margin="0,5,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="30,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" Content="Guardar"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
