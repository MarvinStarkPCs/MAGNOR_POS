<Window x:Class="MAGNOR_POS.Views.UserFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gestión de Usuario"
        Height="600" Width="550"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6B7280"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#146e39" Padding="20">
            <TextBlock x:Name="TitleText" Text="Nuevo Usuario"
                       FontSize="20" FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">
                <!-- Basic Information -->
                <TextBlock Text="Información Básica" FontSize="16" FontWeight="Bold"
                           Foreground="#146e39" Margin="0,0,0,15"/>

                <TextBlock Text="Nombre Completo *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="FullNameTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Nombre de Usuario *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="UsernameTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Correo Electrónico" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="EmailTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,15"/>

                <!-- Role Assignment -->
                <TextBlock Text="Rol del Usuario *" FontSize="16" FontWeight="Bold"
                           Foreground="#146e39" Margin="0,20,0,15"/>

                <TextBlock Text="Rol" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="RoleComboBox"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          Style="{StaticResource ComboBoxStyle}"
                          Margin="0,0,0,15"/>
                <TextBlock Text="El rol determina los permisos y módulos accesibles"
                           FontSize="12" Foreground="#6B7280" Margin="0,-10,0,15"/>

                <!-- Password Section -->
                <TextBlock x:Name="PasswordSectionTitle" Text="Contraseña *"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#146e39" Margin="0,20,0,15"/>

                <TextBlock x:Name="PasswordLabel" Text="Contraseña" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordBoxStyle}" Margin="0,0,0,15"/>

                <TextBlock x:Name="ConfirmPasswordLabel" Text="Confirmar Contraseña" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource PasswordBoxStyle}" Margin="0,0,0,15"/>

                <CheckBox x:Name="ChangePasswordCheckBox" Content="Cambiar contraseña"
                          FontSize="13" Margin="0,0,0,15" Visibility="Collapsed"
                          Checked="ChangePasswordCheckBox_Checked"
                          Unchecked="ChangePasswordCheckBox_Unchecked"/>

                <TextBlock Text="La contraseña debe tener al menos 6 caracteres"
                           FontSize="12" Foreground="#6B7280" Margin="0,-10,0,15"/>

                <!-- Status -->
                <CheckBox x:Name="IsActiveCheckBox" Content="Usuario activo"
                          FontSize="14" IsChecked="True"
                          Margin="0,10,0,15"/>
                <TextBlock Text="Solo los usuarios activos pueden iniciar sesión"
                           FontSize="12" Foreground="#6B7280" Margin="25,-10,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>
                <Button Content="Guardar" Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
