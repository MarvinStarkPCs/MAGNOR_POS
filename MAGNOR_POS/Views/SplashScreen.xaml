<Window x:Class="MAGNOR_POS.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SplashScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True">

    <Window.Resources>
        <!-- Pulse Animation for Logo -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LogoImage"
                           Storyboard.TargetProperty="Opacity"
                           From="0.7"
                           To="1.0"
                           Duration="0:0:1.5"
                           AutoReverse="True"/>
        </Storyboard>

        <!-- Loading Bar Animation -->
        <Storyboard x:Key="LoadingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingBar"
                           Storyboard.TargetProperty="(Canvas.Left)"
                           From="-150"
                           To="550"
                           Duration="0:0:1.5"/>
        </Storyboard>

        <!-- Spinning Animation -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                           Storyboard.TargetProperty="Angle"
                           From="0"
                           To="360"
                           Duration="0:0:1.5"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Background with Blur Effect -->
        <Grid.Background>
            <SolidColorBrush Color="#80000000" Opacity="0.9"/>
        </Grid.Background>

        <!-- Floating Card -->
        <Border Width="550"
                Height="650"
                Background="White"
                CornerRadius="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                Direction="270"
                                ShadowDepth="20"
                                Opacity="0.4"
                                BlurRadius="40"/>
            </Border.Effect>

            <!-- Card Content -->
            <Grid>
                <!-- Top Gradient Bar -->
                <Border Height="8"
                        VerticalAlignment="Top"
                        CornerRadius="20,20,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#146e39" Offset="0"/>
                            <GradientStop Color="#276691" Offset="0.5"/>
                            <GradientStop Color="#146e39" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Main Content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Logo -->
                    <Border Background="#F5F5F5"
                            Width="180"
                            Height="180"
                            CornerRadius="90"
                            Padding="25"
                            Margin="0,0,0,30">
                        <Border.Effect>
                            <DropShadowEffect Color="#CCCCCC"
                                            Direction="270"
                                            ShadowDepth="5"
                                            Opacity="0.3"
                                            BlurRadius="15"/>
                        </Border.Effect>

                        <Image x:Name="LogoImage"
                               Source="/Assets/Images/logo_login.png"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- App Name -->
                    <TextBlock Text="MAGNOR POS"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="#146e39"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- Subtitle -->
                    <TextBlock Text="Sistema de Punto de Venta"
                               FontSize="16"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,50"/>

                    <!-- Loading Spinner -->
                    <Grid Width="50" Height="50" Margin="0,0,0,20">
                        <Ellipse Width="50" Height="50"
                                 Stroke="#E0E0E0"
                                 StrokeThickness="4"
                                 Opacity="0.3"/>

                        <Ellipse Width="50" Height="50"
                                 Stroke="#f78921"
                                 StrokeThickness="4"
                                 StrokeDashArray="35,15"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>

                    <!-- Loading Text -->
                    <TextBlock x:Name="LoadingText"
                               Text="Cargando..."
                               FontSize="16"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Progress Bar -->
                    <Border Width="400"
                            Height="4"
                            Background="#E0E0E0"
                            CornerRadius="2"
                            Margin="0,20,0,0">
                        <Canvas ClipToBounds="True">
                            <Rectangle x:Name="LoadingBar"
                                     Width="150"
                                     Height="4"
                                     Canvas.Left="-150"
                                     RadiusX="2"
                                     RadiusY="2">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#146e39" Offset="0"/>
                                        <GradientStop Color="#276691" Offset="0.5"/>
                                        <GradientStop Color="#f78921" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Canvas>
                    </Border>

                </StackPanel>

                <!-- Version Info at Bottom -->
                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,30">
                    <TextBlock Text="Versión 1.0.0"
                               FontSize="12"
                               Foreground="#999999"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="© 2024 MAGNOR. Todos los derechos reservados."
                               FontSize="11"
                               Foreground="#BBBBBB"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
