<Window x:Class="MAGNOR_POS.Views.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Height"
        Width="420"
        MaxHeight="500"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="White" CornerRadius="15" Margin="10"
            BorderThickness="2" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.3" ShadowDepth="3"/>
        </Border.Effect>

        <Grid Margin="25,20,25,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with icon and title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock x:Name="TxtIcon" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtTitle" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock Grid.Row="1" x:Name="TxtMessage"
                       FontSize="14" Foreground="#444444"
                       TextWrapping="Wrap" Margin="0,0,0,20"
                       LineHeight="22"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" x:Name="ButtonPanel"
                        Orientation="Horizontal" HorizontalAlignment="Right">
            </StackPanel>
        </Grid>
    </Border>
</Window>
