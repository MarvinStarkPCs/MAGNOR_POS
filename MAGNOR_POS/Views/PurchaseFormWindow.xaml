<Window x:Class="MAGNOR_POS.Views.PurchaseFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compra" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F9FAFB">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6B7280"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2563EB" Padding="25,20">
            <TextBlock x:Name="HeaderText" Text="Nueva Orden de Compra"
                       FontSize="24" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
            <StackPanel>
                <!-- Purchase Information Section -->
                <TextBlock Text="Información de la Compra" FontSize="16" FontWeight="Bold"
                           Foreground="#1F2937" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Proveedor *" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="SupplierComboBox" Style="{StaticResource ComboBoxStyle}"
                                  DisplayMemberPath="CompanyName"
                                  SelectedValuePath="Id"
                                  Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha de Compra *" Style="{StaticResource LabelStyle}"/>
                        <DatePicker x:Name="PurchaseDatePicker"
                                    FontSize="14"
                                    Padding="10"
                                    BorderBrush="#D1D5DB"
                                    SelectedDate="{x:Static System:DateTime.Now}"
                                    Margin="0,0,0,15"
                                    xmlns:System="clr-namespace:System;assembly=mscorlib"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Fecha de Entrega Estimada" Style="{StaticResource LabelStyle}"/>
                        <DatePicker x:Name="DeliveryDatePicker"
                                    FontSize="14"
                                    Padding="10"
                                    BorderBrush="#D1D5DB"
                                    Margin="0,0,0,15"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="N° Factura Proveedor" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="SupplierInvoiceTextBox" Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Notas" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="NotesTextBox" Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Products Section -->
                <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,20,0,0" Margin="0,10,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Productos" FontSize="16" FontWeight="Bold"
                                       Foreground="#1F2937" VerticalAlignment="Center"/>

                            <Button x:Name="AddProductButton" Content="+ Agregar Producto"
                                    Style="{StaticResource AddButton}"
                                    HorizontalAlignment="Right"
                                    Click="AddProductButton_Click"/>
                        </Grid>

                        <!-- Product Entry Form -->
                        <Border x:Name="ProductEntryPanel" Background="#F9FAFB" BorderBrush="#E5E7EB"
                                BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Agregar Producto" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Producto" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox x:Name="ProductComboBox" Style="{StaticResource ComboBoxStyle}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Id"
                                                  SelectionChanged="ProductComboBox_SelectionChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Cantidad" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="QuantityTextBox" Style="{StaticResource TextBoxStyle}"
                                                 Text="1" TextChanged="CalculateLineTotal"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Precio Unitario" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="UnitCostTextBox" Style="{StaticResource TextBoxStyle}"
                                                 Text="0" TextChanged="CalculateLineTotal"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Descuento %" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="DiscountTextBox" Style="{StaticResource TextBoxStyle}"
                                                 Text="0" TextChanged="CalculateLineTotal"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="8" VerticalAlignment="Bottom">
                                        <Button Content="Agregar"
                                                Style="{StaticResource AddButton}"
                                                Click="AddToDetailsButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock x:Name="LineTotalText" Text="Total línea: $0.00"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#059669"
                                           Margin="0,10,0,0" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <!-- Products DataGrid -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                                Background="White" MinHeight="200">
                            <DataGrid x:Name="DetailsDataGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F3F4F6"
                                      RowHeight="40"
                                      HeadersVisibility="Column"
                                      FontSize="13">

                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F9FAFB"/>
                                        <Setter Property="Foreground" Value="#374151"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    </Style>

                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                    </Style>

                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F9FAFB"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Producto" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Quantity}" Width="100"/>
                                    <DataGridTextColumn Header="Precio Unit." Width="120">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="UnitCost" StringFormat="C2"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Desc. %" Binding="{Binding DiscountPercentage}" Width="80"/>
                                    <DataGridTextColumn Header="Subtotal" Width="120">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="Subtotal" StringFormat="C2"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="IVA" Width="100">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="TaxAmount" StringFormat="C2"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Total" Width="120">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="Total" StringFormat="C2"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Acción" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Eliminar"
                                                        Style="{StaticResource DeleteButton}"
                                                        Click="RemoveDetailButton_Click"
                                                        Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Totals Section -->
                <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="8" Padding="20" Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Subtotal:" FontSize="14" Foreground="#6B7280"/>
                                <TextBlock x:Name="SubtotalText" Text="$0.00"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" Foreground="#374151"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="IVA (19%):" FontSize="14" Foreground="#6B7280"/>
                                <TextBlock x:Name="TaxText" Text="$0.00"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" Foreground="#374151"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Descuento:" FontSize="14" Foreground="#6B7280"/>
                                <TextBlock x:Name="DiscountTotalText" Text="$0.00"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" Foreground="#EF4444"/>
                            </Grid>

                            <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                <Grid>
                                    <TextBlock Text="TOTAL:" FontSize="18" FontWeight="Bold" Foreground="#1F2937"/>
                                    <TextBlock x:Name="TotalText" Text="$0.00"
                                               FontSize="20" FontWeight="Bold"
                                               HorizontalAlignment="Right" Foreground="#059669"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="30,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" Content="Guardar Compra"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
